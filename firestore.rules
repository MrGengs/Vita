rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi bantuan untuk mengecek apakah user sudah login
    function isAuthenticated() {
      return request.auth != null;
    }

    // Fungsi bantuan untuk memastikan user hanya mengakses datanya sendiri
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Profil Pengguna
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Log Makanan Harian
    match /meals/{userId}/logs/{mealId} {
      allow read, write: if isOwner(userId);
    }

    // 3. Riwayat Analisis Risiko Metabolik
    match /risk_assessments/{userId}/history/{assessmentId} {
      allow read, write: if isOwner(userId);
    }

    // 4. Riwayat Percakapan AI Konsultan
    match /ai_sessions/{userId}/conversations/{sessionId} {
      allow read, write: if isOwner(userId);
    }

    // TOLAK semua akses lain secara default (Secure by default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}