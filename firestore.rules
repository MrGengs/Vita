rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Semua data user tersimpan di bawah users/{userId}
    match /users/{userId} {
      // Profil utama
      allow read, write: if isOwner(userId);

      // Log makanan harian — users/{userId}/meals/{mealId}
      match /meals/{mealId} {
        allow read, write: if isOwner(userId);
      }

      // Riwayat analisis risiko — users/{userId}/risk_assessments/{assessmentId}
      match /risk_assessments/{assessmentId} {
        allow read, write: if isOwner(userId);
      }

      // Riwayat percakapan AI — users/{userId}/ai_sessions/{sessionId}
      match /ai_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Tolak semua akses di luar users/{userId}
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
